{
    "name": "RPG MO Assistant",
    "description": "RPG MO tools",
    "version": "1.1.27",
    "manifest_version": 3,
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "https://api.nopecha.com/*"
    ],
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "notifications",
        "downloads",
        "tabs"
    ],
    "content_scripts": [
        {
            "js": [
                "init.js"
            ],
            "css": [
                "rma.css"
            ],
            "matches": [
                "https://rpg-de.mo.ee/*",
                "https://data.mo.ee/*"
            ],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "libs/reef.min.js",
                "utils.js",
                "menu.js",
                "main.js",
                "builder/actions.js",
                "builder/builder.js",
                "popup.js", 
                "automation/healing.js", 
                "automation/fight.js",
                "automation/farming.js",
                "automation/inventory.js",
                "menu.html", 
                "captcha-notifier.js", 
                "img/rma-logo.png",
                "img/notification.png",
                "img/target.png",
                "img/icon16.png",
                "img/icon48.png",
                "img/icon128.png"
            ],
            "matches": [
                "https://rpg-de.mo.ee/*",
                "https://data.mo.ee/*"
            ]
        }
    ],
    "icons": {
        "16": "img/icon16.png",
        "48": "img/icon48.png",
        "128": "img/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "img/icon16.png",
            "48": "img/icon48.png",
            "128": "img/icon128.png"
        }
    }
}